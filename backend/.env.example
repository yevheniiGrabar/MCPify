APP_NAME=MCPify
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mcpify
DB_USERNAME=mcpify
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@mcpify.io"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (transactional email)
RESEND_API_KEY=

# AWS S3 (optional, for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FRONTEND_URL=http://localhost:5173

MCP_WORKER_URL=http://localhost:3001
MCP_WORKER_SECRET=
MCP_WORKER_ALLOWED_IPS=127.0.0.1,::1

# Freemius (Billing)
FREEMIUS_PRODUCT_ID=
FREEMIUS_PUBLIC_KEY=
FREEMIUS_SECRET_KEY=
FREEMIUS_PLAN_STARTER=
FREEMIUS_PLAN_GROWTH=
FREEMIUS_PLAN_BUSINESS=

# Sentry (error tracking)
SENTRY_LARAVEL_DSN=

# Telescope (dev only)
TELESCOPE_ENABLED=true
